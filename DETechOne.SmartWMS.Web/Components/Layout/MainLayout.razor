@inherits LayoutComponentBase

<div class="page swms-shell">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 swms-topbar">
            <div>
                <span class="fw-semibold">DETechOne SmartWMS</span>
                <span class="text-muted small ms-2">Operacion WMS</span>
            </div>
            <AuthUserMenu />
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<LoadingOverlay />
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>
