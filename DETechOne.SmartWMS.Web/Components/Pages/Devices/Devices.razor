@attribute [SmartWmsAuthorize]
@page "/devices"
@using DETechOne.SmartWMS.Contracts.Dtos.Device
@using DETechOne.SmartWMS.Contracts.Requests.Device
@using DETechOne.SmartWMS.Contracts.Responses
@using DETechOne.SmartWMS.Domain.Enums
@inject DETechOne.SmartWMS.Web.Services.Api.ISmartWmsApiClient ApiClient

<PageTitle>Devices | SmartWMS</PageTitle>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1>Devices</h1>
        <p class="text-muted mb-0">Registra handhelds, monitorea heartbeats y prueba sesiones de scanner.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="LoadOnlineDevicesAsync" disabled="@_isBusy">
        @(_isBusy ? "Actualizando..." : "Actualizar online")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="row g-3 mb-4">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Registrar dispositivo</h2>
            <EditForm Model="_registerForm" OnValidSubmit="RegisterDeviceAsync" FormName="RegisterDeviceForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Device code</label>
                        <InputText class="form-control" @bind-Value="_registerForm.DeviceCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <InputText class="form-control" @bind-Value="_registerForm.Name" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tipo</label>
                        <InputSelect class="form-select" @bind-Value="_registerForm.DeviceType" disabled="@_isBusy">
                            @foreach (var value in Enum.GetValues<DeviceType>())
                            {
                                <option value="@value">@value</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Modelo</label>
                        <InputText class="form-control" @bind-Value="_registerForm.Model" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Platform</label>
                        <InputText class="form-control" @bind-Value="_registerForm.Platform" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">App version</label>
                        <InputText class="form-control" @bind-Value="_registerForm.AppVersion" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Serial</label>
                        <InputText class="form-control" @bind-Value="_registerForm.SerialNumber" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Warehouse</label>
                        <InputText class="form-control" @bind-Value="_registerForm.WarehouseCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">IP</label>
                        <InputText class="form-control" @bind-Value="_registerForm.IpAddress" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">
                    @(_isBusy ? "Registrando..." : "Registrar")
                </button>
            </EditForm>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Scanner session</h2>

            <EditForm Model="_sessionForm" OnValidSubmit="StartSessionAsync" FormName="StartScannerSessionForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Device code</label>
                        <InputText class="form-control" @bind-Value="_sessionForm.DeviceCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Operacion</label>
                        <InputText class="form-control" @bind-Value="_sessionForm.Operation" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Referencia</label>
                        <InputText class="form-control" @bind-Value="_sessionForm.ReferenceDocument" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">
                    @(_isBusy ? "Iniciando..." : "Iniciar sesion")
                </button>
            </EditForm>

            @if (_selectedSession is not null)
            {
                <hr />
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                    <div>
                        <div class="fw-semibold">@_selectedSession.Operation</div>
                        <div class="text-muted small">@_selectedSession.DeviceCode · @_selectedSession.Id</div>
                    </div>
                    <StatusBadge Status="@_selectedSession.Status.ToString()" />
                </div>

                <EditForm Model="_scanForm" OnValidSubmit="SubmitScanAsync" FormName="SubmitScanForm">
                    <DataAnnotationsValidator />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Evento</label>
                            <InputSelect class="form-select" @bind-Value="_scanForm.EventType" disabled="@_isBusy">
                                @foreach (var value in Enum.GetValues<ScannerEventType>())
                                {
                                    <option value="@value">@value</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Valor</label>
                            <InputText class="form-control" @bind-Value="_scanForm.Value" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Symbology</label>
                            <InputText class="form-control" @bind-Value="_scanForm.Symbology" disabled="@_isBusy" />
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button class="btn btn-primary" type="submit" disabled="@_isBusy">Enviar scan</button>
                        <button class="btn btn-outline-success" type="button" @onclick="CompleteSessionAsync" disabled="@_isBusy">Completar</button>
                    </div>
                </EditForm>

                <EditForm Model="_cancelForm" OnValidSubmit="CancelSessionAsync" FormName="CancelScannerSessionForm">
                    <DataAnnotationsValidator />
                    <div class="input-group mt-3">
                        <InputText class="form-control" @bind-Value="_cancelForm.Reason" disabled="@_isBusy" />
                        <button class="btn btn-outline-danger" type="submit" disabled="@_isBusy">Cancelar sesion</button>
                    </div>
                    <ValidationMessage For="@(() => _cancelForm.Reason)" />
                </EditForm>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Dispositivos online</h2>
            @if (_isLoadingDevices)
            {
                <div class="text-muted">Cargando dispositivos...</div>
            }
            else if (_onlineDevices.Count == 0)
            {
                <div class="alert alert-warning mb-0">No hay dispositivos online.</div>
            }
            else
            {
                <div class="list-group swms-document-list">
                    @foreach (var device in _onlineDevices)
                    {
                        <button class="list-group-item list-group-item-action @(device.DeviceCode == _selectedDevice?.DeviceCode ? "active" : string.Empty)" type="button" @onclick="() => SelectDeviceAsync(device.DeviceCode)">
                            <div class="d-flex justify-content-between gap-2">
                                <span>@device.DeviceCode</span>
                                <span>@device.Status</span>
                            </div>
                            <small>@device.Name · @device.Model</small>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Detalle</h2>
            @if (_selectedDevice is null)
            {
                <div class="text-muted">Sin dispositivo seleccionado.</div>
            }
            else
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Status</span>
                            <strong>@_selectedDevice.Status</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Version</span>
                            <strong>@_selectedDevice.AppVersion</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Heartbeat</span>
                            <strong>@FormatDate(_selectedDevice.LastHeartbeatAtUtc)</strong>
                        </div>
                    </div>
                </div>

                <EditForm Model="_heartbeatForm" OnValidSubmit="SendHeartbeatAsync" FormName="DeviceHeartbeatForm">
                    <DataAnnotationsValidator />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">App version</label>
                            <InputText class="form-control" @bind-Value="_heartbeatForm.AppVersion" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">IP</label>
                            <InputText class="form-control" @bind-Value="_heartbeatForm.IpAddress" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-outline-primary w-100" type="submit" disabled="@_isBusy">Enviar heartbeat</button>
                        </div>
                    </div>
                </EditForm>

                @if (_selectedSession is not null)
                {
                    <hr />
                    <h3 class="h6">Scans de la sesion</h3>
                    @if (_selectedSession.Events.Count == 0)
                    {
                        <div class="text-muted">Sin scans registrados.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Valor</th>
                                        <th>Symbology</th>
                                        <th>Fuente</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var scan in _selectedSession.Events.OrderByDescending(item => item.ScannedAtUtc))
                                    {
                                        <tr>
                                            <td>@scan.EventType</td>
                                            <td>@scan.Value</td>
                                            <td>@(scan.Symbology ?? "-")</td>
                                            <td>@(scan.Source ?? "-")</td>
                                            <td>@FormatDate(scan.ScannedAtUtc)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

@code {
    private readonly RegisterDeviceFormModel _registerForm = new();
    private readonly HeartbeatFormModel _heartbeatForm = new();
    private readonly SessionFormModel _sessionForm = new();
    private readonly ScanFormModel _scanForm = new();
    private readonly CancelSessionFormModel _cancelForm = new();
    private List<DeviceRegistrationDto> _onlineDevices = new();
    private DeviceRegistrationDto? _selectedDevice;
    private ScannerSessionDto? _selectedSession;
    private bool _isBusy;
    private bool _isLoadingDevices;
    private string? _message;
    private string? _error;

    protected override Task OnInitializedAsync()
    {
        return LoadOnlineDevicesAsync();
    }

    private async Task LoadOnlineDevicesAsync()
    {
        _isLoadingDevices = true;
        _error = null;

        try
        {
            var response = await ApiClient.GetAsync<ApiResponse<IReadOnlyCollection<DeviceRegistrationDto>>>("api/devices/online");
            if (response is null)
            {
                _error = "La API no devolvio dispositivos.";
                return;
            }

            if (!response.Success || response.Data is null)
            {
                _error = response.Message ?? "No fue posible cargar dispositivos online.";
                return;
            }

            _onlineDevices = response.Data.ToList();
            if (_selectedDevice is not null)
            {
                _selectedDevice = _onlineDevices.FirstOrDefault(item => item.DeviceCode == _selectedDevice.DeviceCode) ?? _selectedDevice;
            }
        }
        catch
        {
            _error = "No fue posible conectar con la API de dispositivos.";
        }
        finally
        {
            _isLoadingDevices = false;
        }
    }

    private async Task RegisterDeviceAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new RegisterDeviceRequest
            {
                DeviceCode = _registerForm.DeviceCode,
                Name = _registerForm.Name,
                DeviceType = _registerForm.DeviceType,
                Model = _registerForm.Model,
                Platform = _registerForm.Platform,
                AppVersion = _registerForm.AppVersion,
                SerialNumber = NormalizeOptional(_registerForm.SerialNumber),
                WarehouseCode = NormalizeOptional(_registerForm.WarehouseCode),
                IpAddress = NormalizeOptional(_registerForm.IpAddress)
            };

            var response = await ApiClient.PostAsync<RegisterDeviceRequest, ApiResponse<DeviceRegistrationDto>>("api/devices/register", request);
            if (!ApplyDeviceResponse(response, "No fue posible registrar el dispositivo."))
            {
                return;
            }

            _message = response?.Message ?? "Dispositivo registrado correctamente.";
            SyncDeviceDefaults(_selectedDevice);
            await LoadOnlineDevicesAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de dispositivos.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SelectDeviceAsync(string deviceCode)
    {
        ClearMessages();

        try
        {
            var response = await ApiClient.GetAsync<ApiResponse<DeviceRegistrationDto>>($"api/devices/{deviceCode}");
            if (ApplyDeviceResponse(response, "No fue posible cargar el dispositivo."))
            {
                SyncDeviceDefaults(_selectedDevice);
            }
        }
        catch
        {
            _error = "No fue posible conectar con la API de dispositivos.";
        }
    }

    private async Task SendHeartbeatAsync()
    {
        if (_selectedDevice is null)
        {
            _error = "Selecciona un dispositivo antes de enviar heartbeat.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DeviceHeartbeatRequest
            {
                DeviceCode = _selectedDevice.DeviceCode,
                AppVersion = NormalizeOptional(_heartbeatForm.AppVersion),
                IpAddress = NormalizeOptional(_heartbeatForm.IpAddress)
            };

            var response = await ApiClient.PostAsync<DeviceHeartbeatRequest, ApiResponse<DeviceHeartbeatDto>>("api/devices/heartbeat", request);
            if (response is null || !response.Success || response.Data is null)
            {
                _error = response?.Message ?? "No fue posible enviar heartbeat.";
                return;
            }

            _message = response.Message ?? "Heartbeat registrado correctamente.";
            await SelectDeviceAsync(_selectedDevice.DeviceCode);
            await LoadOnlineDevicesAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de dispositivos.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task StartSessionAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new StartScannerSessionRequest
            {
                DeviceCode = _sessionForm.DeviceCode,
                Operation = _sessionForm.Operation,
                ReferenceDocument = NormalizeOptional(_sessionForm.ReferenceDocument)
            };

            var response = await ApiClient.PostAsync<StartScannerSessionRequest, ApiResponse<ScannerSessionDto>>("api/devices/scanner-sessions/start", request);
            ApplySessionResponse(response, "No fue posible iniciar la sesion.");
            _message = response?.Message ?? "Sesion iniciada correctamente.";
        }
        catch
        {
            _error = "No fue posible conectar con la API de scanner.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SubmitScanAsync()
    {
        if (_selectedSession is null)
        {
            _error = "Inicia una sesion antes de enviar scans.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new SubmitScanRequest
            {
                ScannerSessionId = _selectedSession.Id,
                EventType = _scanForm.EventType,
                Value = _scanForm.Value,
                Symbology = NormalizeOptional(_scanForm.Symbology),
                Source = NormalizeOptional(_scanForm.Source)
            };

            var response = await ApiClient.PostAsync<SubmitScanRequest, ApiResponse<ScannerEventDto>>("api/devices/scanner-sessions/scan", request);
            if (response is null || !response.Success || response.Data is null)
            {
                _error = response?.Message ?? "No fue posible registrar el scan.";
                return;
            }

            _message = response.Message ?? "Scan registrado correctamente.";
            await RefreshSelectedSessionAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de scanner.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private Task CompleteSessionAsync()
    {
        if (_selectedSession is null)
        {
            _error = "Selecciona una sesion antes de completarla.";
            return Task.CompletedTask;
        }

        var request = new CompleteScannerSessionRequest { ScannerSessionId = _selectedSession.Id };
        return PostSessionActionAsync("api/devices/scanner-sessions/complete", request, "Sesion completada correctamente.", "No fue posible completar la sesion.");
    }

    private Task CancelSessionAsync()
    {
        if (_selectedSession is null)
        {
            _error = "Selecciona una sesion antes de cancelarla.";
            return Task.CompletedTask;
        }

        var request = new CancelScannerSessionRequest { Reason = _cancelForm.Reason };
        return PostSessionActionAsync($"api/devices/scanner-sessions/{_selectedSession.Id}/cancel", request, "Sesion cancelada correctamente.", "No fue posible cancelar la sesion.");
    }

    private async Task PostSessionActionAsync<TRequest>(string endpoint, TRequest request, string successMessage, string fallbackMessage)
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var response = await ApiClient.PostAsync<TRequest, ApiResponse<ScannerSessionDto>>(endpoint, request);
            if (!ApplySessionResponse(response, fallbackMessage))
            {
                return;
            }

            _message = response?.Message ?? successMessage;
        }
        catch
        {
            _error = "No fue posible conectar con la API de scanner.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RefreshSelectedSessionAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        var response = await ApiClient.GetAsync<ApiResponse<ScannerSessionDto>>($"api/devices/scanner-sessions/{_selectedSession.Id}");
        ApplySessionResponse(response, "No fue posible actualizar la sesion.");
    }

    private bool ApplyDeviceResponse(ApiResponse<DeviceRegistrationDto>? response, string fallbackMessage)
    {
        if (response is null || !response.Success || response.Data is null)
        {
            _error = response?.Message ?? fallbackMessage;
            return false;
        }

        _selectedDevice = response.Data;
        return true;
    }

    private bool ApplySessionResponse(ApiResponse<ScannerSessionDto>? response, string fallbackMessage)
    {
        if (response is null || !response.Success || response.Data is null)
        {
            _error = response?.Message ?? fallbackMessage;
            return false;
        }

        _selectedSession = response.Data;
        return true;
    }

    private void SyncDeviceDefaults(DeviceRegistrationDto? device)
    {
        if (device is null)
        {
            return;
        }

        _heartbeatForm.AppVersion = device.AppVersion;
        _heartbeatForm.IpAddress = device.LastIpAddress;
        _sessionForm.DeviceCode = device.DeviceCode;
    }

    private void ClearMessages()
    {
        _message = null;
        _error = null;
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";
    }

    private sealed class RegisterDeviceFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string DeviceCode { get; set; } = "TC15-001";

        [System.ComponentModel.DataAnnotations.Required]
        public string Name { get; set; } = "Zebra TC15 Piso 1";

        public DeviceType DeviceType { get; set; } = DeviceType.ZebraTc15;

        [System.ComponentModel.DataAnnotations.Required]
        public string Model { get; set; } = "TC15";

        [System.ComponentModel.DataAnnotations.Required]
        public string Platform { get; set; } = "Android";

        [System.ComponentModel.DataAnnotations.Required]
        public string AppVersion { get; set; } = "1.0.0";

        public string? SerialNumber { get; set; } = "SN-TC15-001";

        public string? WarehouseCode { get; set; } = "WH-01";

        public string? IpAddress { get; set; } = "192.168.1.50";
    }

    private sealed class HeartbeatFormModel
    {
        public string? AppVersion { get; set; } = "1.0.0";
        public string? IpAddress { get; set; } = "192.168.1.50";
    }

    private sealed class SessionFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string DeviceCode { get; set; } = "TC15-001";

        [System.ComponentModel.DataAnnotations.Required]
        public string Operation { get; set; } = "Picking";

        public string? ReferenceDocument { get; set; } = "SO-DEMO-001";
    }

    private sealed class ScanFormModel
    {
        public ScannerEventType EventType { get; set; } = ScannerEventType.DataWedgeIntent;

        [System.ComponentModel.DataAnnotations.Required]
        public string Value { get; set; } = "ITEM-001";

        public string? Symbology { get; set; } = "CODE128";
        public string? Source { get; set; } = "DataWedge";
    }

    private sealed class CancelSessionFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Reason { get; set; } = "Cancelacion operativa";
    }
}
