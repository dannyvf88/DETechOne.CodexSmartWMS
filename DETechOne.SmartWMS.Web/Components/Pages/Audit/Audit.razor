@attribute [SmartWmsAuthorize]
@page "/audit"
@using DETechOne.SmartWMS.Contracts.Dtos.Audit
@using DETechOne.SmartWMS.Contracts.Requests.Audit
@using DETechOne.SmartWMS.Contracts.Responses
@inject DETechOne.SmartWMS.Web.Services.Api.ISmartWmsApiClient ApiClient

<PageTitle>Audit | SmartWMS</PageTitle>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1>Audit</h1>
        <p class="text-muted mb-0">Consulta y registra eventos operativos de auditoria.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="SearchEventsAsync" disabled="@_isBusy">
        @(_isBusy ? "Consultando..." : "Consultar eventos")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="row g-3 mb-4">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Filtros</h2>
            <EditForm Model="_queryForm" OnValidSubmit="SearchEventsAsync" FormName="AuditSearchForm">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Modulo</label>
                        <InputText class="form-control" @bind-Value="_queryForm.Module" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Accion</label>
                        <InputText class="form-control" @bind-Value="_queryForm.Action" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Entity type</label>
                        <InputText class="form-control" @bind-Value="_queryForm.EntityType" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Entity ID</label>
                        <InputText class="form-control" @bind-Value="_queryForm.EntityId" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Usuario</label>
                        <InputText class="form-control" @bind-Value="_queryForm.UserName" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Device code</label>
                        <InputText class="form-control" @bind-Value="_queryForm.DeviceCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Correlation ID</label>
                        <InputText class="form-control" @bind-Value="_queryForm.CorrelationId" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Pagina</label>
                        <InputNumber class="form-control" @bind-Value="_queryForm.Page" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Tamano</label>
                        <InputNumber class="form-control" @bind-Value="_queryForm.PageSize" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">Buscar</button>
            </EditForm>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Registrar evento</h2>
            <EditForm Model="_createForm" OnValidSubmit="CreateEventAsync" FormName="CreateAuditEventForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Modulo</label>
                        <InputText class="form-control" @bind-Value="_createForm.Module" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Accion</label>
                        <InputText class="form-control" @bind-Value="_createForm.Action" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Entity type</label>
                        <InputText class="form-control" @bind-Value="_createForm.EntityType" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Entity ID</label>
                        <InputText class="form-control" @bind-Value="_createForm.EntityId" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Device code</label>
                        <InputText class="form-control" @bind-Value="_createForm.DeviceCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Descripcion</label>
                        <InputText class="form-control" @bind-Value="_createForm.Description" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Payload</label>
                        <InputTextArea class="form-control" rows="4" @bind-Value="_createForm.Payload" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">
                    @(_isBusy ? "Registrando..." : "Registrar evento")
                </button>
            </EditForm>
        </div>
    </div>
</div>

<div class="swms-page-card bg-white p-3">
    <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
        <h2 class="h5 mb-0">Eventos</h2>
        <div class="text-muted small">@_events.TotalCount registros · pagina @_events.Page de @_events.TotalPages</div>
    </div>

    @if (_isBusy && _events.Items.Count == 0)
    {
        <div class="text-muted">Cargando eventos...</div>
    }
    else if (_events.Items.Count == 0)
    {
        <div class="alert alert-warning mb-0">No hay eventos con los filtros actuales.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Modulo</th>
                        <th>Accion</th>
                        <th>Entidad</th>
                        <th>Usuario</th>
                        <th>Device</th>
                        <th>Descripcion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _events.Items)
                    {
                        <tr>
                            <td>@FormatDate(item.OccurredAtUtc)</td>
                            <td>@item.Module</td>
                            <td>@item.Action</td>
                            <td>@item.EntityType / @item.EntityId</td>
                            <td>@item.UserName</td>
                            <td>@(item.DeviceCode ?? "-")</td>
                            <td>@(item.Description ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private readonly AuditQueryFormModel _queryForm = new();
    private readonly CreateAuditFormModel _createForm = new();
    private PagedResult<AuditLogEntryDto> _events = new();
    private bool _isBusy;
    private string? _message;
    private string? _error;

    protected override Task OnInitializedAsync()
    {
        return SearchEventsAsync();
    }

    private async Task SearchEventsAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var response = await ApiClient.GetAsync<ApiResponse<PagedResult<AuditLogEntryDto>>>($"api/audit/events{BuildQueryString()}");
            if (response is null || !response.Success || response.Data is null)
            {
                _error = response?.Message ?? "No fue posible consultar eventos de auditoria.";
                return;
            }

            _events = response.Data;
        }
        catch
        {
            _error = "No fue posible conectar con la API de auditoria.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CreateEventAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new CreateAuditLogRequest
            {
                Module = _createForm.Module,
                Action = _createForm.Action,
                EntityType = _createForm.EntityType,
                EntityId = _createForm.EntityId,
                DeviceCode = NormalizeOptional(_createForm.DeviceCode),
                CorrelationId = NormalizeOptional(_createForm.CorrelationId),
                Description = NormalizeOptional(_createForm.Description),
                Payload = NormalizeOptional(_createForm.Payload)
            };

            var response = await ApiClient.PostAsync<CreateAuditLogRequest, ApiResponse<AuditLogEntryDto>>("api/audit/events", request);
            if (response is null || !response.Success || response.Data is null)
            {
                _error = response?.Message ?? "No fue posible registrar el evento.";
                return;
            }

            _message = response.Message ?? "Evento registrado correctamente.";
            await SearchEventsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de auditoria.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private string BuildQueryString()
    {
        var values = new Dictionary<string, string?>
        {
            ["module"] = NormalizeOptional(_queryForm.Module),
            ["action"] = NormalizeOptional(_queryForm.Action),
            ["entityType"] = NormalizeOptional(_queryForm.EntityType),
            ["entityId"] = NormalizeOptional(_queryForm.EntityId),
            ["userName"] = NormalizeOptional(_queryForm.UserName),
            ["deviceCode"] = NormalizeOptional(_queryForm.DeviceCode),
            ["correlationId"] = NormalizeOptional(_queryForm.CorrelationId),
            ["page"] = Math.Max(1, _queryForm.Page).ToString(),
            ["pageSize"] = Math.Clamp(_queryForm.PageSize, 1, 200).ToString()
        };

        var query = values
            .Where(item => !string.IsNullOrWhiteSpace(item.Value))
            .Select(item => $"{Uri.EscapeDataString(item.Key)}={Uri.EscapeDataString(item.Value!)}");

        return "?" + string.Join("&", query);
    }

    private void ClearMessages()
    {
        _message = null;
        _error = null;
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string FormatDate(DateTime value)
    {
        return value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private sealed class AuditQueryFormModel
    {
        public string? Module { get; set; }
        public string? Action { get; set; }
        public string? EntityType { get; set; }
        public string? EntityId { get; set; }
        public string? UserName { get; set; }
        public string? DeviceCode { get; set; }
        public string? CorrelationId { get; set; }
        public int Page { get; set; } = 1;
        public int PageSize { get; set; } = 50;
    }

    private sealed class CreateAuditFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Module { get; set; } = "Operations";

        [System.ComponentModel.DataAnnotations.Required]
        public string Action { get; set; } = "ManualReview";

        [System.ComponentModel.DataAnnotations.Required]
        public string EntityType { get; set; } = "OperationalCheck";

        [System.ComponentModel.DataAnnotations.Required]
        public string EntityId { get; set; } = Guid.NewGuid().ToString();

        public string? DeviceCode { get; set; } = "WEB";
        public string? CorrelationId { get; set; }
        public string? Description { get; set; } = "Evento manual desde UI operacional.";
        public string? Payload { get; set; } = "{\"source\":\"SmartWMS.Web\"}";
    }
}
