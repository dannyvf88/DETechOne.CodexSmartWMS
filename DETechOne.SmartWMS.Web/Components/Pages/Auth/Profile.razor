@page "/profile"
@attribute [SmartWmsAuthorize]

<PageTitle>Perfil | SmartWMS</PageTitle>

<h1>Perfil de sesión</h1>

<AuthorizeView>
    <Authorized>
        <div class="card swms-page-card">
            <div class="card-body">
                <h2 class="h5">Usuario autenticado</h2>
                <p class="mb-1"><strong>Nombre:</strong> @context.User.Identity?.Name</p>
                <p class="mb-3"><strong>Autenticación:</strong> @context.User.Identity?.AuthenticationType</p>

                <h3 class="h6">Claims</h3>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in context.User.Claims)
                            {
                                <tr>
                                    <td>@claim.Type</td>
                                    <td>@claim.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>
