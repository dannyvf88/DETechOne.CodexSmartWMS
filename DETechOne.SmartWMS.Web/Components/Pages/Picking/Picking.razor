@attribute [SmartWmsAuthorize]
@page "/picking"
@inject DETechOne.SmartWMS.Web.Services.Api.ISmartWmsApiClient ApiClient

<PageTitle>Picking | SmartWMS</PageTitle>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1>Picking</h1>
        <p class="text-muted mb-0">Crea, consulta y ejecuta documentos de picking contra la API.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="LoadOpenPickingsAsync" disabled="@_isBusy">
        @(_isBusy ? "Actualizando..." : "Actualizar abiertos")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="row g-3 mb-4">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Nuevo picking</h2>
            <EditForm Model="_createForm" OnValidSubmit="CreatePickingAsync" FormName="CreatePickingForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Documento origen</label>
                        <InputText class="form-control" @bind-Value="_createForm.SourceDocumentType" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Numero origen</label>
                        <InputText class="form-control" @bind-Value="_createForm.SourceDocumentNumber" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Warehouse</label>
                        <InputText class="form-control" @bind-Value="_createForm.WarehouseCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Item</label>
                        <InputText class="form-control" @bind-Value="_createForm.ItemCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Location</label>
                        <InputText class="form-control" @bind-Value="_createForm.LocationCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cantidad requerida</label>
                        <InputNumber class="form-control" @bind-Value="_createForm.RequiredQuantity" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Lot</label>
                        <InputText class="form-control" @bind-Value="_createForm.LotNumber" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">UoM</label>
                        <InputText class="form-control" @bind-Value="_createForm.UomCode" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">
                    @(_isBusy ? "Creando..." : "Crear picking")
                </button>
            </EditForm>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Ejecucion</h2>

            @if (_selected is null)
            {
                <div class="alert alert-info mb-0">Selecciona un picking abierto para escanear, cerrar o cancelar.</div>
            }
            else
            {
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                    <div>
                        <div class="fw-semibold">@_selected.PickingNumber</div>
                        <div class="text-muted small">@_selected.SourceDocumentType @_selected.SourceDocumentNumber</div>
                    </div>
                    <StatusBadge Status="@_selected.Status" />
                </div>

                <EditForm Model="_scanForm" OnValidSubmit="ScanLineAsync" FormName="ScanPickingForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Linea</label>
                            <InputNumber class="form-control" @bind-Value="_scanForm.LineNumber" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Item</label>
                            <InputText class="form-control" @bind-Value="_scanForm.ItemCode" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Cantidad</label>
                            <InputNumber class="form-control" @bind-Value="_scanForm.Quantity" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Lot</label>
                            <InputText class="form-control" @bind-Value="_scanForm.LotNumber" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Barcode</label>
                            <InputText class="form-control" @bind-Value="_scanForm.Barcode" disabled="@_isBusy" />
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button class="btn btn-primary" type="submit" disabled="@_isBusy">
                            @(_isBusy ? "Registrando..." : "Registrar scan")
                        </button>
                        <button class="btn btn-outline-success" type="button" @onclick="CloseSelectedAsync" disabled="@_isBusy">
                            Cerrar picking
                        </button>
                    </div>
                </EditForm>

                <EditForm Model="_cancelForm" OnValidSubmit="CancelSelectedAsync" FormName="CancelPickingForm">
                    <DataAnnotationsValidator />
                    <div class="input-group mt-3">
                        <InputText class="form-control" @bind-Value="_cancelForm.Reason" disabled="@_isBusy" />
                        <button class="btn btn-outline-danger" type="submit" disabled="@_isBusy">Cancelar</button>
                    </div>
                    <ValidationMessage For="@(() => _cancelForm.Reason)" />
                </EditForm>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Pickings abiertos</h2>
            @if (_isLoadingList)
            {
                <div class="text-muted">Cargando documentos abiertos...</div>
            }
            else if (_openPickings.Count == 0)
            {
                <div class="alert alert-warning mb-0">No hay pickings abiertos.</div>
            }
            else
            {
                <div class="list-group swms-document-list">
                    @foreach (var picking in _openPickings)
                    {
                        <button class="list-group-item list-group-item-action @(picking.Id == _selected?.Id ? "active" : string.Empty)" type="button" @onclick="() => SelectPickingAsync(picking.Id)">
                            <div class="d-flex justify-content-between gap-2">
                                <span>@picking.PickingNumber</span>
                                <span>@picking.Status</span>
                            </div>
                            <small>@picking.SourceDocumentType @picking.SourceDocumentNumber</small>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Detalle</h2>
            @if (_selected is null)
            {
                <div class="text-muted">Sin documento seleccionado.</div>
            }
            else
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Requerido</span>
                            <strong>@FormatDecimal(_selected.RequiredQuantity)</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Pickeado</span>
                            <strong>@FormatDecimal(_selected.PickedQuantity)</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Pendiente</span>
                            <strong>@FormatDecimal(_selected.PendingQuantity)</strong>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Linea</th>
                                <th>Item</th>
                                <th>Location</th>
                                <th>Lot</th>
                                <th class="text-end">Req.</th>
                                <th class="text-end">Pick.</th>
                                <th class="text-end">Pend.</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _selected.Lines)
                            {
                                <tr>
                                    <td>@line.LineNumber</td>
                                    <td>@line.ItemCode</td>
                                    <td>@(line.LocationCode ?? "-")</td>
                                    <td>@(line.LotNumber ?? "-")</td>
                                    <td class="text-end">@FormatDecimal(line.RequiredQuantity)</td>
                                    <td class="text-end">@FormatDecimal(line.PickedQuantity)</td>
                                    <td class="text-end">@FormatDecimal(line.PendingQuantity)</td>
                                    <td><StatusBadge Status="@line.Status" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly CreatePickingFormModel _createForm = new();
    private readonly ScanPickingFormModel _scanForm = new();
    private readonly CancelPickingFormModel _cancelForm = new();
    private List<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto> _openPickings = new();
    private DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto? _selected;
    private bool _isBusy;
    private bool _isLoadingList;
    private string? _error;
    private string? _message;

    protected override Task OnInitializedAsync()
    {
        return LoadOpenPickingsAsync();
    }

    private async Task LoadOpenPickingsAsync()
    {
        _isLoadingList = true;
        _error = null;

        try
        {
            var response = await ApiClient.GetAsync<DETechOne.SmartWMS.Contracts.Responses.ApiResponse<IReadOnlyList<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>>("api/picking/open");
            if (response is null)
            {
                _error = "La API no devolvio pickings abiertos.";
                return;
            }

            if (!response.Success || response.Data is null)
            {
                _error = response.Message ?? "No fue posible cargar pickings abiertos.";
                return;
            }

            _openPickings = response.Data.ToList();
            if (_selected is not null)
            {
                _selected = _openPickings.FirstOrDefault(item => item.Id == _selected.Id) ?? _selected;
            }
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
        finally
        {
            _isLoadingList = false;
        }
    }

    private async Task CreatePickingAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Picking.CreatePickingRequest
            {
                SourceDocumentType = _createForm.SourceDocumentType,
                SourceDocumentNumber = _createForm.SourceDocumentNumber,
                WarehouseCode = _createForm.WarehouseCode,
                Lines = new[]
                {
                    new DETechOne.SmartWMS.Contracts.Requests.Picking.CreatePickingLineRequest
                    {
                        LineNumber = 1,
                        ItemCode = _createForm.ItemCode,
                        WarehouseCode = _createForm.WarehouseCode,
                        LocationCode = NormalizeOptional(_createForm.LocationCode),
                        RequiredQuantity = _createForm.RequiredQuantity,
                        LotNumber = NormalizeOptional(_createForm.LotNumber),
                        UomCode = NormalizeOptional(_createForm.UomCode)
                    }
                }
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Picking.CreatePickingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>("api/picking", request);
            if (!TryApplyDocumentResponse(response, "No fue posible crear el picking."))
            {
                return;
            }

            _message = response?.Message ?? "Picking creado correctamente.";
            await LoadOpenPickingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SelectPickingAsync(Guid pickingId)
    {
        ClearMessages();

        try
        {
            var response = await ApiClient.GetAsync<DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>($"api/picking/{pickingId}");
            if (!TryApplyDocumentResponse(response, "No fue posible cargar el picking."))
            {
                return;
            }

            PrimeScanForm();
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
    }

    private async Task ScanLineAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un picking antes de escanear.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Picking.ScanPickingItemRequest
            {
                PickingId = _selected.Id,
                LineNumber = _scanForm.LineNumber,
                ItemCode = _scanForm.ItemCode,
                Quantity = _scanForm.Quantity,
                Barcode = NormalizeOptional(_scanForm.Barcode),
                LotNumber = NormalizeOptional(_scanForm.LotNumber)
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Picking.ScanPickingItemRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>("api/picking/scan", request);
            if (!TryApplyDocumentResponse(response, "No fue posible registrar el scan."))
            {
                return;
            }

            _message = response?.Message ?? "Scan registrado correctamente.";
            PrimeScanForm();
            await LoadOpenPickingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CloseSelectedAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un picking antes de cerrar.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Picking.ClosePickingRequest { PickingId = _selected.Id };
            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Picking.ClosePickingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>("api/picking/close", request);
            if (!TryApplyDocumentResponse(response, "No fue posible cerrar el picking."))
            {
                return;
            }

            _message = response?.Message ?? "Picking cerrado correctamente.";
            await LoadOpenPickingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CancelSelectedAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un picking antes de cancelar.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Picking.CancelPickingRequest
            {
                PickingId = _selected.Id,
                Reason = _cancelForm.Reason
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Picking.CancelPickingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>>("api/picking/cancel", request);
            if (!TryApplyDocumentResponse(response, "No fue posible cancelar el picking."))
            {
                return;
            }

            _message = response?.Message ?? "Picking cancelado correctamente.";
            await LoadOpenPickingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de picking.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private bool TryApplyDocumentResponse(DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Picking.PickingDocumentDto>? response, string fallbackMessage)
    {
        if (response is null)
        {
            _error = "La API no devolvio respuesta.";
            return false;
        }

        if (!response.Success || response.Data is null)
        {
            _error = response.Message ?? fallbackMessage;
            return false;
        }

        _selected = response.Data;
        return true;
    }

    private void PrimeScanForm()
    {
        var nextLine = _selected?.Lines.FirstOrDefault(line => line.PendingQuantity > 0) ?? _selected?.Lines.FirstOrDefault();
        if (nextLine is null)
        {
            return;
        }

        _scanForm.LineNumber = nextLine.LineNumber;
        _scanForm.ItemCode = nextLine.ItemCode;
        _scanForm.Quantity = Math.Max(1, nextLine.PendingQuantity);
        _scanForm.LotNumber = nextLine.LotNumber;
    }

    private void ClearMessages()
    {
        _error = null;
        _message = null;
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string FormatDecimal(decimal value)
    {
        return value.ToString("0.##");
    }

    private sealed class CreatePickingFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string SourceDocumentType { get; set; } = "SO";

        [System.ComponentModel.DataAnnotations.Required]
        public string SourceDocumentNumber { get; set; } = "SO-1001";

        [System.ComponentModel.DataAnnotations.Required]
        public string WarehouseCode { get; set; } = "WH-01";

        [System.ComponentModel.DataAnnotations.Required]
        public string ItemCode { get; set; } = "ITEM-001";

        public string? LocationCode { get; set; } = "LOC-01";

        [System.ComponentModel.DataAnnotations.Range(typeof(decimal), "0.01", "999999999")]
        public decimal RequiredQuantity { get; set; } = 1;

        public string? LotNumber { get; set; }

        public string? UomCode { get; set; } = "EA";
    }

    private sealed class ScanPickingFormModel
    {
        [System.ComponentModel.DataAnnotations.Range(0, int.MaxValue)]
        public int LineNumber { get; set; } = 1;

        [System.ComponentModel.DataAnnotations.Required]
        public string ItemCode { get; set; } = "ITEM-001";

        [System.ComponentModel.DataAnnotations.Range(typeof(decimal), "0.01", "999999999")]
        public decimal Quantity { get; set; } = 1;

        public string? Barcode { get; set; }

        public string? LotNumber { get; set; }
    }

    private sealed class CancelPickingFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Reason { get; set; } = "Cancelacion operativa";
    }
}
