@attribute [SmartWmsAuthorize]
@page "/packing"
@inject DETechOne.SmartWMS.Web.Services.Api.ISmartWmsApiClient ApiClient

<PageTitle>Packing | SmartWMS</PageTitle>

<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1>Packing</h1>
        <p class="text-muted mb-0">Crea, consulta y ejecuta documentos de packing contra la API.</p>
    </div>
    <button class="btn btn-outline-primary" type="button" @onclick="LoadOpenPackingsAsync" disabled="@_isBusy">
        @(_isBusy ? "Actualizando..." : "Actualizar abiertos")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <div class="alert alert-success">@_message</div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<div class="row g-3 mb-4">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Nuevo packing</h2>
            <EditForm Model="_createForm" OnValidSubmit="CreatePackingAsync" FormName="CreatePackingForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Picking ID</label>
                        <InputText class="form-control" @bind-Value="_createForm.PickingIdText" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Picking number</label>
                        <InputText class="form-control" @bind-Value="_createForm.PickingNumber" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Warehouse</label>
                        <InputText class="form-control" @bind-Value="_createForm.WarehouseCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Item</label>
                        <InputText class="form-control" @bind-Value="_createForm.ItemCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Location</label>
                        <InputText class="form-control" @bind-Value="_createForm.LocationCode" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cantidad picked</label>
                        <InputNumber class="form-control" @bind-Value="_createForm.PickedQuantity" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Lot</label>
                        <InputText class="form-control" @bind-Value="_createForm.LotNumber" disabled="@_isBusy" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">UoM</label>
                        <InputText class="form-control" @bind-Value="_createForm.UomCode" disabled="@_isBusy" />
                    </div>
                </div>

                <button class="btn btn-primary mt-3" type="submit" disabled="@_isBusy">
                    @(_isBusy ? "Creando..." : "Crear packing")
                </button>
            </EditForm>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Ejecucion</h2>

            @if (_selected is null)
            {
                <div class="alert alert-info mb-0">Selecciona un packing abierto para empacar, cerrar o cancelar.</div>
            }
            else
            {
                <div class="d-flex flex-wrap justify-content-between gap-3 mb-3">
                    <div>
                        <div class="fw-semibold">@_selected.PackingNumber</div>
                        <div class="text-muted small">Picking @_selected.PickingNumber</div>
                    </div>
                    <StatusBadge Status="@_selected.Status.ToString()" />
                </div>

                <EditForm Model="_packForm" OnValidSubmit="PackLineAsync" FormName="PackItemForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Linea</label>
                            <InputNumber class="form-control" @bind-Value="_packForm.LineNumber" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Cantidad</label>
                            <InputNumber class="form-control" @bind-Value="_packForm.Quantity" disabled="@_isBusy" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Package code</label>
                            <InputText class="form-control" @bind-Value="_packForm.PackageCode" disabled="@_isBusy" />
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button class="btn btn-primary" type="submit" disabled="@_isBusy">
                            @(_isBusy ? "Empacando..." : "Registrar empaque")
                        </button>
                        <button class="btn btn-outline-success" type="button" @onclick="CloseSelectedAsync" disabled="@_isBusy">
                            Cerrar packing
                        </button>
                    </div>
                </EditForm>

                <EditForm Model="_cancelForm" OnValidSubmit="CancelSelectedAsync" FormName="CancelPackingForm">
                    <DataAnnotationsValidator />
                    <div class="input-group mt-3">
                        <InputText class="form-control" @bind-Value="_cancelForm.Reason" disabled="@_isBusy" />
                        <button class="btn btn-outline-danger" type="submit" disabled="@_isBusy">Cancelar</button>
                    </div>
                    <ValidationMessage For="@(() => _cancelForm.Reason)" />
                </EditForm>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-5">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Packings abiertos</h2>
            @if (_isLoadingList)
            {
                <div class="text-muted">Cargando documentos abiertos...</div>
            }
            else if (_openPackings.Count == 0)
            {
                <div class="alert alert-warning mb-0">No hay packings abiertos.</div>
            }
            else
            {
                <div class="list-group swms-document-list">
                    @foreach (var packing in _openPackings)
                    {
                        <button class="list-group-item list-group-item-action @(packing.Id == _selected?.Id ? "active" : string.Empty)" type="button" @onclick="() => SelectPackingAsync(packing.Id)">
                            <div class="d-flex justify-content-between gap-2">
                                <span>@packing.PackingNumber</span>
                                <span>@packing.Status</span>
                            </div>
                            <small>Picking @packing.PickingNumber</small>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-xl-7">
        <div class="swms-page-card bg-white p-3 h-100">
            <h2 class="h5 mb-3">Detalle</h2>
            @if (_selected is null)
            {
                <div class="text-muted">Sin documento seleccionado.</div>
            }
            else
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Picked</span>
                            <strong>@FormatDecimal(_selected.PickedQuantity)</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Packed</span>
                            <strong>@FormatDecimal(_selected.PackedQuantity)</strong>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="swms-counter-tile">
                            <span>Pendiente</span>
                            <strong>@FormatDecimal(_selected.PendingQuantity)</strong>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Linea</th>
                                <th>Item</th>
                                <th>Location</th>
                                <th>Lot</th>
                                <th>Package</th>
                                <th class="text-end">Picked</th>
                                <th class="text-end">Packed</th>
                                <th class="text-end">Pend.</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _selected.Lines)
                            {
                                <tr>
                                    <td>@line.LineNumber</td>
                                    <td>@line.ItemCode</td>
                                    <td>@(line.LocationCode ?? "-")</td>
                                    <td>@(line.LotNumber ?? "-")</td>
                                    <td>@(line.PackageCode ?? "-")</td>
                                    <td class="text-end">@FormatDecimal(line.PickedQuantity)</td>
                                    <td class="text-end">@FormatDecimal(line.PackedQuantity)</td>
                                    <td class="text-end">@FormatDecimal(line.PendingQuantity)</td>
                                    <td><StatusBadge Status="@line.Status.ToString()" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly CreatePackingFormModel _createForm = new();
    private readonly PackItemFormModel _packForm = new();
    private readonly CancelPackingFormModel _cancelForm = new();
    private List<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto> _openPackings = new();
    private DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto? _selected;
    private bool _isBusy;
    private bool _isLoadingList;
    private string? _error;
    private string? _message;

    protected override Task OnInitializedAsync()
    {
        return LoadOpenPackingsAsync();
    }

    private async Task LoadOpenPackingsAsync()
    {
        _isLoadingList = true;
        _error = null;

        try
        {
            var response = await ApiClient.GetAsync<DETechOne.SmartWMS.Contracts.Responses.ApiResponse<IReadOnlyList<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>>("api/packing/open");
            if (response is null)
            {
                _error = "La API no devolvio packings abiertos.";
                return;
            }

            if (!response.Success || response.Data is null)
            {
                _error = response.Message ?? "No fue posible cargar packings abiertos.";
                return;
            }

            _openPackings = response.Data.ToList();
            if (_selected is not null)
            {
                _selected = _openPackings.FirstOrDefault(item => item.Id == _selected.Id) ?? _selected;
            }
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
        finally
        {
            _isLoadingList = false;
        }
    }

    private async Task CreatePackingAsync()
    {
        _isBusy = true;
        ClearMessages();

        try
        {
            if (!Guid.TryParse(_createForm.PickingIdText, out var pickingId))
            {
                _error = "Picking ID debe ser un GUID valido.";
                return;
            }

            var request = new DETechOne.SmartWMS.Contracts.Requests.Packing.CreatePackingRequest
            {
                PickingId = pickingId,
                PickingNumber = _createForm.PickingNumber,
                WarehouseCode = _createForm.WarehouseCode,
                Lines = new()
                {
                    new DETechOne.SmartWMS.Contracts.Requests.Packing.CreatePackingLineRequest
                    {
                        LineNumber = 1,
                        ItemCode = _createForm.ItemCode,
                        WarehouseCode = _createForm.WarehouseCode,
                        LocationCode = NormalizeOptional(_createForm.LocationCode),
                        PickedQuantity = _createForm.PickedQuantity,
                        LotNumber = NormalizeOptional(_createForm.LotNumber),
                        UomCode = NormalizeOptional(_createForm.UomCode)
                    }
                }
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Packing.CreatePackingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>("api/packing", request);
            if (!TryApplyDocumentResponse(response, "No fue posible crear el packing."))
            {
                return;
            }

            _message = response?.Message ?? "Packing creado correctamente.";
            await LoadOpenPackingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SelectPackingAsync(Guid packingId)
    {
        ClearMessages();

        try
        {
            var response = await ApiClient.GetAsync<DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>($"api/packing/{packingId}");
            if (!TryApplyDocumentResponse(response, "No fue posible cargar el packing."))
            {
                return;
            }

            PrimePackForm();
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
    }

    private async Task PackLineAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un packing antes de empacar.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Packing.PackItemRequest
            {
                PackingId = _selected.Id,
                LineNumber = _packForm.LineNumber,
                Quantity = _packForm.Quantity,
                PackageCode = _packForm.PackageCode
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Packing.PackItemRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>("api/packing/pack", request);
            if (!TryApplyDocumentResponse(response, "No fue posible registrar el empaque."))
            {
                return;
            }

            _message = response?.Message ?? "Empaque registrado correctamente.";
            PrimePackForm();
            await LoadOpenPackingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CloseSelectedAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un packing antes de cerrar.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Packing.ClosePackingRequest { PackingId = _selected.Id };
            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Packing.ClosePackingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>("api/packing/close", request);
            if (!TryApplyDocumentResponse(response, "No fue posible cerrar el packing."))
            {
                return;
            }

            _message = response?.Message ?? "Packing cerrado correctamente.";
            await LoadOpenPackingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CancelSelectedAsync()
    {
        if (_selected is null)
        {
            _error = "Selecciona un packing antes de cancelar.";
            return;
        }

        _isBusy = true;
        ClearMessages();

        try
        {
            var request = new DETechOne.SmartWMS.Contracts.Requests.Packing.CancelPackingRequest
            {
                PackingId = _selected.Id,
                Reason = _cancelForm.Reason
            };

            var response = await ApiClient.PostAsync<DETechOne.SmartWMS.Contracts.Requests.Packing.CancelPackingRequest, DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>>("api/packing/cancel", request);
            if (!TryApplyDocumentResponse(response, "No fue posible cancelar el packing."))
            {
                return;
            }

            _message = response?.Message ?? "Packing cancelado correctamente.";
            await LoadOpenPackingsAsync();
        }
        catch
        {
            _error = "No fue posible conectar con la API de packing.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private bool TryApplyDocumentResponse(DETechOne.SmartWMS.Contracts.Responses.ApiResponse<DETechOne.SmartWMS.Contracts.Dtos.Packing.PackingDocumentDto>? response, string fallbackMessage)
    {
        if (response is null)
        {
            _error = "La API no devolvio respuesta.";
            return false;
        }

        if (!response.Success || response.Data is null)
        {
            _error = response.Message ?? fallbackMessage;
            return false;
        }

        _selected = response.Data;
        return true;
    }

    private void PrimePackForm()
    {
        var nextLine = _selected?.Lines.FirstOrDefault(line => line.PendingQuantity > 0) ?? _selected?.Lines.FirstOrDefault();
        if (nextLine is null)
        {
            return;
        }

        _packForm.LineNumber = nextLine.LineNumber;
        _packForm.Quantity = Math.Max(1, nextLine.PendingQuantity);
        _packForm.PackageCode = nextLine.PackageCode ?? _packForm.PackageCode;
    }

    private void ClearMessages()
    {
        _error = null;
        _message = null;
    }

    private static string? NormalizeOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string FormatDecimal(decimal value)
    {
        return value.ToString("0.##");
    }

    private sealed class CreatePackingFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string PickingIdText { get; set; } = Guid.NewGuid().ToString();

        [System.ComponentModel.DataAnnotations.Required]
        public string PickingNumber { get; set; } = "PICK-MANUAL-001";

        [System.ComponentModel.DataAnnotations.Required]
        public string WarehouseCode { get; set; } = "WH-01";

        [System.ComponentModel.DataAnnotations.Required]
        public string ItemCode { get; set; } = "ITEM-001";

        public string? LocationCode { get; set; } = "LOC-01";

        [System.ComponentModel.DataAnnotations.Range(typeof(decimal), "0.01", "999999999")]
        public decimal PickedQuantity { get; set; } = 1;

        public string? LotNumber { get; set; }

        public string? UomCode { get; set; } = "EA";
    }

    private sealed class PackItemFormModel
    {
        [System.ComponentModel.DataAnnotations.Range(0, int.MaxValue)]
        public int LineNumber { get; set; } = 1;

        [System.ComponentModel.DataAnnotations.Range(typeof(decimal), "0.01", "999999999")]
        public decimal Quantity { get; set; } = 1;

        [System.ComponentModel.DataAnnotations.Required]
        public string PackageCode { get; set; } = "PKG-001";
    }

    private sealed class CancelPackingFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string Reason { get; set; } = "Cancelacion operativa";
    }
}
